# Copy to .env.local and fill in. Never commit .env.local.
# In production, set the same variable names in your host's dashboard (Vercel, Railway, etc.).

# --- Admin code (optional) ---
# 1. Choose a secret code (only you know it), e.g. "MinHemligaKod123" or generate: openssl rand -base64 24
# 2. Add it below (after the =). When you log in as admin, you type this in the "Código de administrador" field.
# 3. Online: set the same ADMIN_CODE in your host's environment variables.
# ADMIN_CODE=MinHemligaKod123

# --- Required (database: Neon PostgreSQL) ---
# Get both from Neon: Dashboard → your project → Connection string.
# Use "Pooled connection" for DATABASE_URL and "Direct connection" for DIRECT_URL.
# For non-Neon Postgres, set both to the same connection string.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Required (auth) ---
# Min 32 chars. Generate: openssl rand -base64 33
AUTH_SECRET=your-secret-at-least-32-chars

# Production: your app URL. Vercel sets this automatically.
# NEXTAUTH_URL=https://your-app.vercel.app
